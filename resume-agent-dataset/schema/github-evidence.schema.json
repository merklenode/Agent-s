{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "github-evidence.schema.json",
  "title": "GitHub Evidence",
  "description": "Validates resume-agent-dataset/evidence/github-evidence.json generated by pnpm github:evidence",
  "type": "object",
  "required": ["updated", "source", "owner", "scope", "generated_by", "repositories"],
  "additionalProperties": false,
  "properties": {
    "updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "ISO 8601 date of the last extraction run"
    },
    "source": {
      "type": "string",
      "enum": ["github"]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "string",
      "enum": ["all_repositories_including_private"]
    },
    "generated_by": {
      "type": "string",
      "enum": ["pnpm github:evidence"]
    },
    "repositories": {
      "type": "array",
      "items": { "$ref": "#/definitions/RepoRecord" }
    }
  },
  "definitions": {
    "RepoRecord": {
      "type": "object",
      "required": [
        "repo_name",
        "full_name",
        "github_url",
        "visibility",
        "is_fork",
        "is_archived",
        "description",
        "topics",
        "homepage_url",
        "default_branch",
        "primary_language",
        "languages_detected",
        "dependency_files_detected",
        "frameworks_detected",
        "tools_detected",
        "important_files_detected",
        "readme",
        "activity",
        "resume_evidence_signals",
        "extraction_warnings"
      ],
      "additionalProperties": false,
      "properties": {
        "repo_name": { "type": "string", "minLength": 1 },
        "full_name": {
          "type": "string",
          "pattern": "^[^/]+/[^/]+$"
        },
        "github_url": { "type": "string", "format": "uri" },
        "visibility": {
          "type": "string",
          "enum": ["public", "private"]
        },
        "is_fork": { "type": "boolean" },
        "is_archived": { "type": "boolean" },
        "description": { "type": "string" },
        "topics": {
          "type": "array",
          "items": { "type": "string" }
        },
        "homepage_url": { "type": ["string", "null"] },
        "default_branch": { "type": "string", "minLength": 1 },
        "primary_language": { "type": ["string", "null"] },
        "languages_detected": {
          "type": "array",
          "items": { "type": "string" }
        },
        "dependency_files_detected": {
          "type": "array",
          "items": { "type": "string" }
        },
        "frameworks_detected": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tools_detected": {
          "type": "array",
          "items": { "type": "string" }
        },
        "important_files_detected": {
          "type": "array",
          "items": { "type": "string" }
        },
        "readme": { "$ref": "#/definitions/ReadmeData" },
        "activity": { "$ref": "#/definitions/ActivityData" },
        "resume_evidence_signals": { "$ref": "#/definitions/ResumeEvidenceSignals" },
        "extraction_warnings": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "ReadmeData": {
      "type": "object",
      "required": ["exists", "path", "plain_text_excerpt", "detected_sections"],
      "additionalProperties": false,
      "properties": {
        "exists": { "type": "boolean" },
        "path": { "type": ["string", "null"] },
        "plain_text_excerpt": { "type": "string" },
        "detected_sections": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "ActivityData": {
      "type": "object",
      "required": ["last_pushed_at", "created_at", "updated_at", "recent_commit_count"],
      "additionalProperties": false,
      "properties": {
        "last_pushed_at": { "type": "string" },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" },
        "recent_commit_count": { "type": "integer", "minimum": 0 }
      }
    },
    "ResumeEvidenceSignals": {
      "type": "object",
      "required": ["possible_profiles", "technical_keywords", "confidence"],
      "additionalProperties": false,
      "properties": {
        "possible_profiles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "technical_keywords": {
          "type": "array",
          "items": { "type": "string" }
        },
        "confidence": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        }
      }
    }
  }
}
