# LocusGraph SDK configuration
# Copy this file to .env and fill in real values. Never commit .env.

# Required — your LocusGraph agent secret
LOCUSGRAPH_AGENT_SECRET=your-agent-secret-here

# Optional — LocusGraph API endpoint (default: https://api.locusgraph.com)
LOCUSGRAPH_SERVER_URL=https://api.locusgraph.com

# Optional — graph identifier (default: default)
LOCUSGRAPH_GRAPH_ID=default
